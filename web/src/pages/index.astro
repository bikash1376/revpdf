---
import Layout from '../layouts/Layout.astro';

// In development — distributed as a direct APK for now. The Play Store
// listing will replace APK_URL once it's live.
const APK_URL = '/revpdf.apk';
const CONTACT_EMAIL = 'bikash13763@gmail.com';

// Real device screenshots from web/public/screenshots/. screen-1 is featured
// in the hero; the rest fill the gallery below.
const heroShot = '/screenshots/screen-1.gif';
const shots = [
  '/screenshots/screen-2.jpeg',
  '/screenshots/screen-3.jpeg',
  '/screenshots/screen-4.jpeg',
  '/screenshots/screen-5.jpeg',
  '/screenshots/screen-6.jpeg',
];

const features = [
  {
    icon: 'menu_book',
    title: 'PDF & EPUB, done right',
    body: 'Open PDFs and reflowable EPUBs in one quiet reader. Continuous scroll or page-by-page — your choice.',
  },
  {
    icon: 'ink_highlighter',
    title: 'Highlight in any color',
    body: 'Long-press to select, then mark passages with a full palette of highlight colors that stay readable on every theme.',
  },
  {
    icon: 'palette',
    title: 'Four reading themes',
    body: 'Light, Sepia, Twilight and Dark — applied to the page only, independent of the app’s own theme. Twilight even tints PDFs.',
  },
  {
    icon: 'zoom_in',
    title: 'Zoom & typography',
    body: 'Pinch to zoom anywhere. For EPUB, tune font, size, weight, spacing, margins and alignment to taste.',
  },
  {
    icon: 'search',
    title: 'Select to search',
    body: 'Highlight a word and search it instantly in a built-in sheet — Google, DuckDuckGo, Yandex or Yahoo, your pick.',
  },
  {
    icon: 'lock',
    title: 'Private by design',
    body: 'Everything stays on your device. No accounts, no servers, no tracking. Your library is yours alone.',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Android · PDF &amp; EPUB reader</span>
      <h1>Read in peace.</h1>
      <p class="lead">
        revpdf is a minimalist reader that keeps the page in front and the controls out of the way.
        Highlights, reader themes, zoom and search — entirely offline.
      </p>
      <p class="dev-note">
        <span class="material-symbols-outlined">construction</span>
        <span
          ><strong>In development.</strong> Coming to the Google Play Store soon — for now you can grab
          the APK and install it directly.</span
        >
      </p>
      <div class="hero-cta" id="download">
        <a class="btn btn-filled" href={APK_URL} download>
          <span class="material-symbols-outlined">android</span>
          Download APK
        </a>
        <a class="btn btn-tonal" href="#features">See features</a>
      </div>
      <p class="fineprint muted">
        Free · No ads · No account required · Found a bug?{' '}
        <a href={`mailto:${CONTACT_EMAIL}?subject=revpdf%20feedback`}>Send feedback</a>
      </p>
    </div>

    <!-- Hero screenshot -->
    <div class="device">
      <img class="device-shot" src={heroShot} alt="revpdf reading screen" width="300" height="633" />
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="section-head">
      <h2>Everything you need, nothing you don’t</h2>
      <p class="muted">A reader that respects your attention and your data.</p>
    </div>
    <div class="grid">
      {
        features.map((f) => (
          <article class="card">
            <span class="card-icon material-symbols-outlined">{f.icon}</span>
            <h3>{f.title}</h3>
            <p class="muted">{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Screenshots -->
  <section class="section" id="screenshots">
    <div class="section-head">
      <h2>See it in action</h2>
      <p class="muted">A few screens from the app. Quiet by default.</p>
    </div>
    <div class="shots">
      <div class="shots-track">
        {
          shots.map((s, i) => (
            <figure class="shot">
              <img src={s} alt={`revpdf screen ${i + 2}`} loading="lazy" />
            </figure>
          ))
        }
        {/* Duplicate set so the loop is seamless. */}
        {
          shots.map((s) => (
            <figure class="shot" aria-hidden="true">
              <img src={s} alt="" loading="lazy" />
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  {/* Video walkthrough — re-enable once a clip is recorded.
  <section class="section video-section" id="demo">
    <div class="section-head">
      <h2>Watch the walkthrough</h2>
      <p class="muted">A quick look at importing, reading and highlighting.</p>
    </div>
    <div class="video-frame">
      <video controls playsinline preload="none" poster="/media/demo-poster.png">
        <source src="/media/demo.mp4" type="video/mp4" />
        Your browser doesn’t support embedded video.
      </video>
    </div>
  </section>
  */}

  <!-- CTA band -->
  <section class="cta-band">
    <div class="cta-inner">
      <h2>Bring your library along.</h2>
      <p>Import a PDF or EPUB and start reading in seconds. No sign-up, no upload.</p>
      <a class="btn btn-filled" href={APK_URL} download>
        <span class="material-symbols-outlined">android</span>
        Download APK
      </a>
      <p class="cta-fine">
        Currently in development — Play Store coming soon. Questions or bug reports?{' '}
        <a href={`mailto:${CONTACT_EMAIL}?subject=revpdf%20feedback`}>{CONTACT_EMAIL}</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(40px, 7vw, 88px) clamp(16px, 5vw, 40px);
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .eyebrow {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
    background: var(--primary-container);
    padding: 6px 12px;
    border-radius: 999px;
    margin-bottom: 18px;
  }
  .hero h1 {
    font-size: clamp(40px, 7vw, 68px);
    font-weight: 700;
  }
  .lead {
    font-size: clamp(17px, 2.2vw, 20px);
    color: var(--on-surface-variant);
    max-width: 46ch;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 28px 0 12px;
  }
  .fineprint {
    font-size: 14px;
  }
  .fineprint a {
    font-weight: 500;
  }
  .dev-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    max-width: 46ch;
    margin: 18px 0 0;
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    background: var(--primary-container);
    color: var(--on-primary-container);
    font-size: 15px;
    line-height: 1.5;
  }
  .dev-note .material-symbols-outlined {
    font-size: 20px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* hero device frame */
  .device {
    justify-self: center;
    width: min(300px, 80vw);
    background: #11131a;
    border-radius: 38px;
    padding: 12px;
    box-shadow: var(--shadow-2);
  }
  .device-shot {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 28px;
  }

  /* features */
  .section-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .section-head h2 {
    font-size: clamp(28px, 4vw, 40px);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--outline);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-1);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-2);
  }
  .card-icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--primary-container);
    color: var(--primary-deep);
    font-size: 28px;
    margin-bottom: 16px;
  }
  .card h3 {
    font-size: 19px;
  }
  .card p {
    margin: 0;
  }

  /* screenshots — auto-scrolling marquee, ~3 visible at a time */
  .shots {
    --gap: clamp(14px, 2vw, 28px);
    --pad: clamp(16px, 5vw, 40px);
    overflow: hidden;
    /* fade the edges so cards slide in/out softly */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
    mask-image: linear-gradient(to right, transparent, #000 6%, #000 94%, transparent);
  }
  .shots-track {
    display: flex;
    gap: var(--gap);
    width: max-content;
    animation: shots-scroll 36s linear infinite;
  }
  .shots:hover .shots-track {
    animation-play-state: paused;
  }
  .shot {
    flex: 0 0 auto;
    width: clamp(200px, calc((min(100vw, var(--maxw)) - 2 * var(--pad) - 2 * var(--gap)) / 3), 360px);
    margin: 0;
  }
  .shot img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 720 / 1600;
    object-fit: cover;
    border-radius: 24px;
    border: 1px solid var(--outline);
    box-shadow: var(--shadow-1);
    background: var(--surface-variant);
  }
  @keyframes shots-scroll {
    from {
      transform: translateX(0);
    }
    to {
      /* shift by exactly one set (half the duplicated track + one gap) */
      transform: translateX(calc(-50% - var(--gap) / 2));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .shots {
      overflow-x: auto;
    }
    .shots-track {
      animation: none;
    }
  }

  /* video */
  .video-section {
    padding-top: 0;
  }
  .video-frame {
    max-width: 880px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    border: 1px solid var(--outline);
    background: #000;
  }
  .video-frame video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--surface-variant);
  }

  /* cta band */
  .cta-band {
    background: linear-gradient(135deg, var(--primary-deep), var(--primary));
    color: var(--on-primary);
  }
  .cta-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(48px, 7vw, 80px) clamp(16px, 5vw, 40px);
    text-align: center;
  }
  .cta-inner h2 {
    font-size: clamp(28px, 4vw, 40px);
  }
  .cta-inner p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 18px;
    margin-bottom: 28px;
  }
  .cta-inner .btn-filled {
    background: var(--on-primary);
    color: var(--primary);
  }
  .cta-fine {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8) !important;
    margin: 20px 0 0 !important;
  }
  .cta-fine a {
    color: #fff;
    font-weight: 500;
    text-decoration: underline;
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero .lead {
      margin-inline: auto;
    }
    .hero-cta {
      justify-content: center;
    }
    .device {
      order: -1;
      margin-bottom: 8px;
    }
  }

  @media (max-width: 520px) {
    .hero-cta .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
