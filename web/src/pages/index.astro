---
import Layout from '../layouts/Layout.astro';

const PLAY_STORE_URL = '#'; // TODO: replace with the real Play Store listing

// Drop real device screenshots into web/public/screenshots/ (same filenames) to
// replace the generated placeholders.
const shots = [
  { src: '/screenshots/light.png', caption: 'Light' },
  { src: '/screenshots/sepia.png', caption: 'Sepia' },
  { src: '/screenshots/twilight.png', caption: 'Twilight' },
  { src: '/screenshots/dark.png', caption: 'Dark' },
];

const features = [
  {
    icon: 'menu_book',
    title: 'PDF & EPUB, done right',
    body: 'Open PDFs and reflowable EPUBs in one quiet reader. Continuous scroll or page-by-page — your choice.',
  },
  {
    icon: 'ink_highlighter',
    title: 'Highlight in any color',
    body: 'Long-press to select, then mark passages with a full palette of highlight colors that stay readable on every theme.',
  },
  {
    icon: 'palette',
    title: 'Four reading themes',
    body: 'Light, Sepia, Twilight and Dark — applied to the page only, independent of the app’s own theme. Twilight even tints PDFs.',
  },
  {
    icon: 'zoom_in',
    title: 'Zoom & typography',
    body: 'Pinch to zoom anywhere. For EPUB, tune font, size, weight, spacing, margins and alignment to taste.',
  },
  {
    icon: 'search',
    title: 'Select to search',
    body: 'Highlight a word and search it instantly in a built-in sheet — Google, DuckDuckGo, Yandex or Yahoo, your pick.',
  },
  {
    icon: 'lock',
    title: 'Private by design',
    body: 'Everything stays on your device. No accounts, no servers, no tracking. Your library is yours alone.',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Android · PDF &amp; EPUB reader</span>
      <h1>Read in peace.</h1>
      <p class="lead">
        revpdf is a minimalist reader that keeps the page in front and the controls out of the way.
        Highlights, reader themes, zoom and search — entirely offline.
      </p>
      <div class="hero-cta" id="download">
        <a class="btn btn-filled" href={PLAY_STORE_URL}>
          <span class="material-symbols-outlined">android</span>
          Get it on Google Play
        </a>
        <a class="btn btn-tonal" href="#features">See features</a>
      </div>
      <p class="fineprint muted">Free · No ads · No account required</p>
    </div>

    <!-- CSS device mock -->
    <div class="device" aria-hidden="true">
      <div class="device-screen">
        <div class="page-title">The Alignment Engine</div>
        <p>
          The framework lets a model create a <mark>tree of possibilities</mark>. At each step it
          generates, evaluates and searches — much closer to how people actually think.
        </p>
        <p>
          It can abandon low-scoring branches and backtrack to a more promising one, navigating the
          tree efficiently.
        </p>
        <p class="dim">
          Reinforcement Learning from Human Feedback became the industry’s standard method for this
          task, shaping responses to be helpful, honest and safe.
        </p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="section-head">
      <h2>Everything you need, nothing you don’t</h2>
      <p class="muted">A reader that respects your attention and your data.</p>
    </div>
    <div class="grid">
      {
        features.map((f) => (
          <article class="card">
            <span class="card-icon material-symbols-outlined">{f.icon}</span>
            <h3>{f.title}</h3>
            <p class="muted">{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Screenshots -->
  <section class="section" id="screenshots">
    <div class="section-head">
      <h2>See it in action</h2>
      <p class="muted">The same page, four reading themes. Quiet by default.</p>
    </div>
    <div class="shots">
      {
        shots.map((s) => (
          <figure class="shot">
            <img src={s.src} alt={`revpdf — ${s.caption} theme`} loading="lazy" />
            <figcaption class="muted">{s.caption}</figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- Video -->
  <section class="section video-section" id="demo">
    <div class="section-head">
      <h2>Watch the walkthrough</h2>
      <p class="muted">A quick look at importing, reading and highlighting.</p>
    </div>
    <div class="video-frame">
      <!-- Drop a real clip at web/public/media/demo.mp4 to enable playback. -->
      <video controls playsinline preload="none" poster="/media/demo-poster.png">
        <source src="/media/demo.mp4" type="video/mp4" />
        Your browser doesn’t support embedded video.
      </video>
    </div>
  </section>

  <!-- CTA band -->
  <section class="cta-band">
    <div class="cta-inner">
      <h2>Bring your library along.</h2>
      <p>Import a PDF or EPUB and start reading in seconds. No sign-up, no upload.</p>
      <a class="btn btn-filled" href={PLAY_STORE_URL}>
        <span class="material-symbols-outlined">android</span>
        Download revpdf
      </a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(40px, 7vw, 88px) clamp(16px, 5vw, 40px);
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .eyebrow {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
    background: var(--primary-container);
    padding: 6px 12px;
    border-radius: 999px;
    margin-bottom: 18px;
  }
  .hero h1 {
    font-size: clamp(40px, 7vw, 68px);
    font-weight: 700;
  }
  .lead {
    font-size: clamp(17px, 2.2vw, 20px);
    color: var(--on-surface-variant);
    max-width: 46ch;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 28px 0 12px;
  }
  .fineprint {
    font-size: 14px;
  }

  /* device mock */
  .device {
    justify-self: center;
    width: min(300px, 80vw);
    aspect-ratio: 9 / 19;
    background: #11131a;
    border-radius: 38px;
    padding: 12px;
    box-shadow: var(--shadow-2);
  }
  .device-screen {
    height: 100%;
    background: var(--sepia);
    border-radius: 28px;
    padding: 26px 20px;
    overflow: hidden;
    color: #5b4636;
    font-size: 14px;
  }
  .page-title {
    font-weight: 700;
    font-size: 17px;
    margin-bottom: 14px;
  }
  .device-screen mark {
    background: #ffe082;
    color: inherit;
    border-radius: 3px;
    padding: 0 2px;
  }
  .device-screen .dim {
    opacity: 0.7;
  }

  /* features */
  .section-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .section-head h2 {
    font-size: clamp(28px, 4vw, 40px);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--outline);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-1);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-2);
  }
  .card-icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--primary-container);
    color: var(--primary-deep);
    font-size: 28px;
    margin-bottom: 16px;
  }
  .card h3 {
    font-size: 19px;
  }
  .card p {
    margin: 0;
  }

  /* screenshots */
  .shots {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(12px, 2.5vw, 24px);
  }
  .shot {
    margin: 0;
    text-align: center;
  }
  .shot img {
    width: 100%;
    height: auto;
    aspect-ratio: 9 / 19;
    object-fit: cover;
    border-radius: 22px;
    border: 1px solid var(--outline);
    box-shadow: var(--shadow-1);
    background: var(--surface-variant);
  }
  .shot figcaption {
    margin-top: 10px;
    font-size: 14px;
    font-weight: 500;
  }

  /* video */
  .video-section {
    padding-top: 0;
  }
  .video-frame {
    max-width: 880px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    border: 1px solid var(--outline);
    background: #000;
  }
  .video-frame video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--surface-variant);
  }

  /* cta band */
  .cta-band {
    background: linear-gradient(135deg, var(--primary-deep), var(--primary));
    color: var(--on-primary);
  }
  .cta-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(48px, 7vw, 80px) clamp(16px, 5vw, 40px);
    text-align: center;
  }
  .cta-inner h2 {
    font-size: clamp(28px, 4vw, 40px);
  }
  .cta-inner p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 18px;
    margin-bottom: 28px;
  }
  .cta-inner .btn-filled {
    background: var(--on-primary);
    color: var(--primary);
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero .lead {
      margin-inline: auto;
    }
    .hero-cta {
      justify-content: center;
    }
    .device {
      order: -1;
      margin-bottom: 8px;
    }
    .shots {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .hero-cta .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
